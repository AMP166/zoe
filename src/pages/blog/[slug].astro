---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getPosts, imageSrc } from '../../lib/sanity';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post: any) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const paragraphs = Array.isArray(post.body) && typeof post.body[0] === 'string' ? post.body : (post.bodyText || '').split(/\n+/).filter(Boolean);
---
<BaseLayout title={`${post.title} | Zoe Pedersen`} description={post.excerpt}>
  <Header />
  <main class="article-main">
    <article class="article">
      <p class="eyebrow">{post.category} · {post.location}</p>
      <h1>{post.title}</h1>
      <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
      <img class="article-image" src={imageSrc(post, '/assets/zoe-hero.jpg')} alt={post.title} />
      <div class="article-body">
        {paragraphs.length ? paragraphs.map((block: any) => typeof block === 'string' ? <p>{block}</p> : null) : <p>{post.excerpt}</p>}
      </div>
      <a class="text-link" href="/blog">← Back to all updates</a>
    </article>
  </main>
  <Footer />
</BaseLayout>
